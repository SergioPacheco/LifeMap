---
import { defaultLocale, supportedLocales } from '../i18n';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const localeList = JSON.stringify(supportedLocales);
const fallbackLocale = defaultLocale;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0;url=${base}/${fallbackLocale}/`} />
    <title>LifeMap Pro</title>
    <script is:inline define:vars={{ base, localeList, fallbackLocale }}>
      (() => {
        const supported = JSON.parse(localeList);
        const getCookieLocale = () => {
          const match = document.cookie.match(/(?:^|;\s*)lifemap-locale=([a-z]{2})/);
          return match && supported.includes(match[1]) ? match[1] : null;
        };
        const getBrowserLocale = () => {
          const lang = (navigator.language || '').toLowerCase().split('-')[0];
          return supported.includes(lang) ? lang : null;
        };
        let locale = null;
        try {
          locale = localStorage.getItem('lifemap-locale');
        } catch {}
        locale = locale && supported.includes(locale) ? locale : getCookieLocale() || getBrowserLocale() || fallbackLocale;
        window.location.replace(`${base}/${locale}/`);
      })();
    </script>
  </head>
  <body>
    <noscript>
      <a href={`${base}/${fallbackLocale}/`}>LifeMap Pro</a>
    </noscript>
  </body>
</html>
