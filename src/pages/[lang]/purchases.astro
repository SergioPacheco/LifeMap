---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PurchasesPage from '../../components/premium/PurchasesPage.tsx';
import { getTranslations, supportedLocales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---

<BaseLayout title={locale === 'pt' ? 'Meus Relatórios' : 'My Reports'} locale={locale}>
  <PurchasesPage client:load locale={locale} />
</BaseLayout>
