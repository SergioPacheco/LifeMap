---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReportPreview from '../../../components/premium/ReportPreview.tsx';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---

<BaseLayout title={locale === 'pt' ? 'Previsão Anual' : 'Annual Forecast'} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-6 text-center">
      <nav class="text-sm text-muted mb-4">
        <a href={`/${locale}/reports`} class="hover:text-brand-600">{t.reports.title}</a> → <span class="text-cream">{locale === 'pt' ? 'Previsão Anual' : 'Annual Forecast'}</span>
      </nav>
    </div>
    <ReportPreview client:load locale={locale} reportType="annual" />
  </div>
</BaseLayout>
