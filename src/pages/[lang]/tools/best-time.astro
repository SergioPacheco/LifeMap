---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
import BestTime from '../../../components/tools/BestTime.tsx';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---

<BaseLayout title="Melhor Momento" locale={locale}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-gold text-xs uppercase tracking-widest font-semibold">Astrologia Eletiva</span>
      </div>
      <h1 class="text-2xl font-serif font-bold text-cream">Melhor Momento</h1>
      <p class="text-sm text-muted mt-1">
        Descubra o que os planetas regentes de cada dia favorecem — e o que é melhor adiar
      </p>
    </div>
    <BestTime client:load />
  </div>
</BaseLayout>
