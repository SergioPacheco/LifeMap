---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AspectCalendarApp from '../../../components/chart/AspectCalendarApp.tsx';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---
<BaseLayout title={t.nav.aspectCalendar} locale={locale}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-serif font-bold text-cream">{t.nav.aspectCalendar}</h1>
    </div>
    <AspectCalendarApp client:load />
  </div>
</BaseLayout>
