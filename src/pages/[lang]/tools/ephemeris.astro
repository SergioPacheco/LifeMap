---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
import EphemerisApp from '../../../components/chart/EphemerisApp.tsx';
---
<BaseLayout title={t.nav.ephemeris} locale={locale}><div class="max-w-7xl mx-auto px-4 sm:px-6 py-8"><EphemerisApp client:load /></div></BaseLayout>
