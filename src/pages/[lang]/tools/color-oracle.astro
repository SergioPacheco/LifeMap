---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ColorOracle from '../../../components/tools/ColorOracle.tsx';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---
<BaseLayout title="Oráculo de Cores" locale={locale}>
  <div class="max-w-2xl mx-auto px-4 py-12 text-center">
    <ColorOracle client:load />
  </div>
</BaseLayout>
