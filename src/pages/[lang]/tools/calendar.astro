---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
import AstroCalendarApp from '../../../components/chart/AstroCalendarApp.tsx';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---

<BaseLayout title="Calendário Astrológico" locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <AstroCalendarApp client:load locale={locale} />
  </div>
</BaseLayout>
