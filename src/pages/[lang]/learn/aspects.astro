---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
import { getContent } from '../../../content';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
const content = await getContent(locale, 'aspects');
---

<BaseLayout title={content.title} locale={locale}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <nav class="text-sm text-muted mb-6">
      <a href={`/${locale}/learn`} class="hover:text-brand-600">{t.nav.learn}</a> → <span class="text-cream">{content.title}</span>
    </nav>
    <h1 class="text-3xl font-serif font-bold text-cream mb-4">{content.title}</h1>
    <p class="text-muted mb-8 text-lg">{content.intro}</p>

    <div class="flex gap-4 mb-8 text-sm">
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-blue-600"></span> {content.colorLegend.harmonic}</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-600"></span> {content.colorLegend.tense}</span>
    </div>

    <div class="space-y-8">
      {content.list.map((asp: any) => (
        <article class="bg-base-50 rounded-xl border border-base-300 p-6 shadow-sm" style={`border-left: 4px solid ${asp.color}`}>
          <div class="flex items-start gap-4">
            <div class="text-4xl flex-shrink-0" style={`color: ${asp.color}`}>{asp.symbol}</div>
            <div class="flex-1">
              <h2 class="text-xl font-serif font-bold text-cream">{asp.name}</h2>
              <div class="flex flex-wrap gap-3 mt-1 text-xs text-muted">
                <span>{t.common.angle}: <strong>{asp.angle}</strong></span>
                <span>{t.common.orb}: <strong>{asp.orb}</strong></span>
                <span style={`color: ${asp.color}`}>● {asp.nature}</span>
              </div>
              <p class="mt-3 text-sm text-cream-dark leading-relaxed">{asp.description}</p>
              <p class="mt-2 text-xs text-muted italic">💡 {asp.example}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
