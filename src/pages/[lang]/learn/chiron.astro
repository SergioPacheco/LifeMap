---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';
import { getContent } from '../../../content';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
const content = await getContent(locale, 'chiron');
---

<BaseLayout title={content.title} locale={locale}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-muted mb-6">
      <a href={localePath('/learn', locale)} class="hover:text-brand-600">{t.nav.learn}</a> → <span class="text-cream">{content.title}</span>
    </nav>

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl text-gold">⚷</span>
        <h1 class="text-3xl font-serif font-bold text-cream">{content.title}</h1>
      </div>
      <p class="text-muted text-lg leading-relaxed">{content.intro}</p>
    </div>

    <!-- Mythology -->
    <section class="mb-10">
      <h2 class="text-2xl font-serif font-bold text-cream mb-4">{content.mythology.title}</h2>
      <div class="bg-base-50 border border-base-300 rounded-xl p-6 space-y-4">
        <p class="text-cream-dark leading-relaxed">{content.mythology.text}</p>
        <div class="border-l-4 border-gold/40 pl-4">
          <p class="text-cream-dark leading-relaxed italic">{content.mythology.wound}</p>
        </div>
        <div class="bg-gold/5 border border-gold/20 rounded-lg p-4">
          <p class="text-gold text-sm font-medium leading-relaxed">{content.mythology.meaning}</p>
        </div>
      </div>
    </section>

    <!-- Chiron nos Signos -->
    <section class="mb-10">
      <h2 class="text-2xl font-serif font-bold text-cream mb-2">{content.signsTitle}</h2>
      <p class="text-muted mb-6">{content.signsIntro}</p>
      <div class="grid gap-3 sm:grid-cols-2">
        {content.signs.map((item: any) => (
          <div class="bg-base-50 border border-base-300 rounded-xl p-4">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-gold font-semibold text-sm">{item.sign}</span>
              <span class="text-xs text-muted">{item.years}</span>
            </div>
            <p class="text-xs text-muted mb-1"><strong class="text-cream-dark">Ferida:</strong> {item.wound}</p>
            <p class="text-xs text-muted"><strong class="text-cream-dark">Cura:</strong> {item.healing}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Chiron nas Casas -->
    <section class="mb-10">
      <h2 class="text-2xl font-serif font-bold text-cream mb-2">{content.housesTitle}</h2>
      <p class="text-muted mb-6">{content.housesIntro}</p>
      <div class="space-y-3">
        {content.houses.map((house: any) => (
          <article class="bg-base-50 border border-base-300 rounded-xl p-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 flex items-center justify-center bg-gold/10 rounded-full text-gold font-bold text-sm flex-shrink-0">{house.num}</div>
              <div class="flex-1">
                <h3 class="font-semibold text-cream mb-1">{house.name}</h3>
                <p class="text-xs text-muted mb-1">🩹 {house.wound}</p>
                <p class="text-xs text-gold">✨ {house.gift}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Como Curar -->
    <section class="mb-10">
      <h2 class="text-2xl font-serif font-bold text-cream mb-2">{content.healingTitle}</h2>
      <p class="text-muted mb-6">{content.healingIntro}</p>
      <div class="space-y-4">
        {content.healingSteps.map((step: any) => (
          <div class="bg-base-50 border border-base-300 rounded-xl p-5 flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-gold/10 rounded-full flex items-center justify-center">
              <span class="text-gold text-xs font-bold">{step.step.charAt(0)}</span>
            </div>
            <div>
              <p class="font-semibold text-cream text-sm mb-1">{step.step}</p>
              <p class="text-sm text-cream-dark leading-relaxed">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <div class="mt-10 p-6 bg-gold/5 rounded-xl border border-gold/20 text-center">
      <p class="text-sm text-gold font-medium">{content.cta}</p>
      <a href={localePath('/chart/natal', locale)} class="inline-block mt-3 px-6 py-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium rounded-lg transition-colors">{content.ctaButton}</a>
    </div>
  </div>
</BaseLayout>
