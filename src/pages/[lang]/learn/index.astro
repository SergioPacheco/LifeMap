---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
import { getContent } from '../../../content';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
const content = await getContent(locale, 'learn');
---

<BaseLayout title={content.title} locale={locale}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-serif font-bold text-cream">{content.title}</h1>
      <p class="text-muted mt-2 max-w-2xl mx-auto">{content.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {content.sections.map((section: any) => (
        <a href={`/${locale}/learn/${section.slug}`} class="group p-6 bg-base-50 rounded-xl border border-base-300 hover:border-gold/40 hover:shadow-gold transition-all">
          <div class="text-3xl mb-3">{section.icon}</div>
          <h2 class="text-lg font-semibold text-cream group-hover:text-gold transition-colors">{section.title}</h2>
          <p class="mt-2 text-sm text-muted">{section.description}</p>
        </a>
      ))}
      <a href={`/${locale}/reports`} class="group p-6 bg-gradient-to-br from-gold-dark/10 to-gold/5 rounded-xl border border-gold/30 hover:border-gold/60 hover:shadow-gold transition-all">
        <div class="text-3xl mb-3">{content.premiumCta.icon}</div>
        <h2 class="text-lg font-semibold text-gold">{content.premiumCta.title}</h2>
        <p class="mt-2 text-sm text-gold-muted">{content.premiumCta.description}</p>
      </a>
    </div>
  </div>
</BaseLayout>
