---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';
import { getContent } from '../../../content';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
const content = await getContent(locale, 'planets');
---

<BaseLayout title={content.title} locale={locale}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <nav class="text-sm text-muted mb-6">
      <a href={localePath('/learn', locale)} class="hover:text-brand-600">{t.nav.learn}</a> → <span class="text-cream">{content.title}</span>
    </nav>
    <h1 class="text-3xl font-serif font-bold text-cream mb-4">{content.title}</h1>
    <p class="text-muted mb-8 text-lg leading-relaxed">{content.intro}</p>

    <div class="space-y-8">
      {content.list.map((planet: any) => (
        <article class="bg-base-50 rounded-xl border border-base-300 p-6 shadow-sm">
          <div class="flex items-start gap-4">
            <div class="text-4xl flex-shrink-0">{planet.symbol}</div>
            <div class="flex-1">
              <h2 class="text-xl font-serif font-bold text-cream">{planet.name}</h2>
              <div class="flex flex-wrap gap-3 mt-1 text-xs text-muted">
                <span>{t.common.ruler}: <strong class="text-cream-dark">{planet.ruler}</strong></span>
                <span>{t.common.cycle}: <strong class="text-cream-dark">{planet.cycle}</strong></span>
              </div>
              <p class="mt-3 text-sm text-cream-dark leading-relaxed">{planet.description}</p>
              <div class="mt-3 flex flex-wrap gap-1">
                {planet.keywords.split(', ').map((kw: string) => (
                  <span class="px-2 py-0.5 bg-gold/5 text-gold text-xs rounded-full">{kw}</span>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-10 p-6 bg-gold/5 rounded-xl border border-gold/20 text-center">
      <p class="text-sm text-gold font-medium">{content.cta}</p>
      <a href={localePath('/chart/natal', locale)} class="inline-block mt-3 px-6 py-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium rounded-lg">{content.ctaButton}</a>
    </div>
  </div>
</BaseLayout>
