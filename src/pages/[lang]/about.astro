---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../i18n';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---
<BaseLayout title={t.nav.about} locale={locale}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-serif font-bold text-cream mb-6">LifeMap Pro</h1>

    <div class="space-y-6">
      <section class="bg-base-50 rounded-xl border border-base-300 p-6">
        <h2 class="text-xl font-semibold text-cream mt-0 mb-3">{t.about.title}</h2>
        <p class="text-muted">
          {t.about.description}
        </p>
      </section>

      <section class="bg-base-50 rounded-xl border border-base-300 p-6">
        <h2 class="text-xl font-semibold text-cream mt-0 mb-3">{t.about.techTitle}</h2>
        <ul class="text-sm text-muted space-y-2">
          <li><strong class="text-cream-dark">Astronomy Engine</strong> — {t.about.techSwiss}</li>
          <li><strong class="text-cream-dark">Astronomy Engine</strong> — {t.about.techAstronomy}</li>
          <li><strong class="text-cream-dark">jsPDF</strong> — {t.about.techJspdf}</li>
          <li><strong class="text-cream-dark">IndexedDB</strong> — {t.about.techIndexeddb}</li>
        </ul>
      </section>

      <section class="bg-base-50 rounded-xl border border-base-300 p-6">
        <h2 class="text-xl font-semibold text-cream mt-0 mb-3">{t.about.privacyTitle}</h2>
        <p class="text-muted">
          {t.about.privacyDesc}
        </p>
      </section>

      <section class="bg-base-50 rounded-xl border border-base-300 p-6">
        <h2 class="text-xl font-semibold text-cream mt-0 mb-3">{t.about.languagesTitle}</h2>
        <p class="text-muted">
          {t.about.languagesDesc} Português, English, Español, Français, Deutsch, Italiano, Nederlands, Türkçe, Русский, 中文, 日本語
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
