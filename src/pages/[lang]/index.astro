---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../i18n';
import { getContent } from '../../content';
import AstroWeather from '../../components/dashboard/AstroWeather';
import ChartMoment from '../../components/chart/ChartMoment';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
const learn = await getContent(locale, 'learn');
---

<BaseLayout title={t.nav.home} locale={locale}>
  <!-- Redirect logic -->
  <script is:inline define:vars={{ locale, base: import.meta.env.BASE_URL.replace(/\/$/, '') }}>
    (function() {
      if (window.location.search.includes('stay')) return;
      const request = indexedDB.open('LifeMapDB');
      request.onsuccess = function(event) {
        const db = event.target.result;
        if (!db.objectStoreNames.contains('profiles')) return;
        const tx = db.transaction('profiles', 'readonly');
        const store = tx.objectStore('profiles');
        const countRequest = store.count();
        countRequest.onsuccess = function() {
          if (countRequest.result > 0) window.location.replace(base + '/' + locale + '/dashboard');
        };
      };
    })();
  </script>

  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(240,184,64,0.06)_0%,_transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_rgba(240,184,64,0.03)_0%,_transparent_40%)]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-gold/[0.02] blur-[100px]"></div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-20 relative text-center">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-xs text-cream-dark mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-gold animate-pulse"></span>
        {t.home.tagline}
      </div>

      <!-- Main headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-serif font-bold text-cream-light leading-[1.1] tracking-tight">
        {t.home.headline}
        <br />
        <span class="bg-gradient-to-r from-gold-dark via-gold to-gold-light bg-clip-text text-transparent">
          {t.home.headlineHighlight}
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-lg sm:text-xl text-cream-dark max-w-2xl mx-auto leading-relaxed">
        {t.site.description}
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={localePath('/onboarding', locale)} class="group relative px-8 py-4 bg-gradient-to-r from-gold-dark via-gold to-gold-light text-black font-bold text-lg rounded-xl transition-all hover:shadow-gold-lg hover:scale-[1.02] active:scale-[0.98]">
          {t.home.cta}
          <span class="ml-2">✦</span>
          <div class="absolute inset-0 rounded-xl bg-gradient-to-r from-gold-dark via-gold to-gold-light opacity-0 group-hover:opacity-20 blur-xl transition-opacity"></div>
        </a>
        <a href={localePath('/reports', locale)} class="px-8 py-4 glass rounded-xl text-cream font-medium hover:border-gold/20 transition-all glow-hover">
          {t.reports.title}
          <span class="ml-2 text-cream-dark">→</span>
        </a>
      </div>

      <!-- Social proof -->
      <div class="mt-12 flex items-center justify-center gap-6 text-xs text-muted">
        <span>{t.home.socialPrivate}</span>
        <span class="w-px h-3 bg-base-400"></span>
        <span>{t.home.socialSwiss}</span>
        <span class="w-px h-3 bg-base-400"></span>
        <span>{t.home.socialOffline}</span>
      </div>
    </div>
  </section>

  <!-- Astro Weather Banner -->
  <section class="py-10">
    <AstroWeather client:load />
  </section>

  <!-- Features grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-serif font-bold text-cream-light">
        {t.home.featuresTitle}
      </h2>
      <p class="text-cream-dark mt-3 max-w-lg mx-auto">
        {t.home.featuresSubtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <a href={localePath('/chart/natal', locale)} class="group p-6 rounded-2xl glass border-glow glow-hover transition-all">
        <div class="text-3xl mb-4">☉</div>
        <h3 class="font-semibold text-cream-light group-hover:text-gold transition-colors">{t.nav.natal}</h3>
        <p class="text-sm text-muted mt-1">{t.home.natalDesc}</p>
      </a>
      <a href={localePath('/chart/transits', locale)} class="group p-6 rounded-2xl glass border-glow glow-hover transition-all">
        <div class="text-3xl mb-4">↻</div>
        <h3 class="font-semibold text-cream-light group-hover:text-gold transition-colors">{t.nav.transits}</h3>
        <p class="text-sm text-muted mt-1">{t.home.transitsDesc}</p>
      </a>
      <a href={localePath('/chart/synastry', locale)} class="group p-6 rounded-2xl glass border-glow glow-hover transition-all">
        <div class="text-3xl mb-4">♡</div>
        <h3 class="font-semibold text-cream-light group-hover:text-gold transition-colors">{t.nav.synastry}</h3>
        <p class="text-sm text-muted mt-1">{t.home.synastryDesc}</p>
      </a>
      <a href={localePath('/horoscope/daily', locale)} class="group p-6 rounded-2xl glass border-glow glow-hover transition-all">
        <div class="text-3xl mb-4">✦</div>
        <h3 class="font-semibold text-cream-light group-hover:text-gold transition-colors">{t.home.horoscopeTitle}</h3>
        <p class="text-sm text-muted mt-1">{t.home.horoscopeDesc}</p>
      </a>
      <a href={localePath('/tools/ephemeris', locale)} class="group p-6 rounded-2xl glass border-glow glow-hover transition-all">
        <div class="text-3xl mb-4">📅</div>
        <h3 class="font-semibold text-cream-light group-hover:text-gold transition-colors">{t.nav.ephemeris}</h3>
        <p class="text-sm text-muted mt-1">{t.home.ephemerisDesc}</p>
      </a>
      <a href={localePath('/reports', locale)} class="group p-6 rounded-2xl border border-gold/20 bg-gold/[0.03] glow-hover transition-all">
        <div class="text-3xl mb-4">📄</div>
        <h3 class="font-semibold text-gold">{t.home.premiumTitle}</h3>
        <p class="text-sm text-gold-muted mt-1">{t.home.premiumDesc}</p>
      </a>
    </div>
  </section>

  <!-- Chart of the Moment widget -->
  <section class="py-10">
    <ChartMoment client:load locale={locale} />
  </section>

  <!-- Trust section -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <div class="glass rounded-2xl p-8 text-center">
      <h3 class="text-xl font-serif font-bold text-cream-light mb-6">
        {t.home.trustTitle}
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div>
          <div class="text-2xl mb-2">🔬</div>
          <h4 class="text-sm font-semibold text-cream-light">Swiss Ephemeris</h4>
          <p class="text-xs text-muted mt-1">{t.home.trustSwissDesc}</p>
        </div>
        <div>
          <div class="text-2xl mb-2">🔒</div>
          <h4 class="text-sm font-semibold text-cream-light">{t.home.trustZeroServers}</h4>
          <p class="text-xs text-muted mt-1">{t.home.trustZeroDesc}</p>
        </div>
        <div>
          <div class="text-2xl mb-2">🌐</div>
          <h4 class="text-sm font-semibold text-cream-light">{t.home.trust11langs}</h4>
          <p class="text-xs text-muted mt-1">{t.home.trust11desc}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
