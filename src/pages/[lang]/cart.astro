---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CartPage from '../../components/cart/CartPage.tsx';
import { getTranslations, supportedLocales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---

<BaseLayout title={locale === 'pt' ? 'Carrinho' : 'Cart'} locale={locale}>
  <CartPage client:load locale={locale} />
</BaseLayout>
