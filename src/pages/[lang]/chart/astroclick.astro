---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AstroClickApp from '../../../components/chart/AstroClickApp.tsx';
import { supportedLocales, type Locale } from '../../../i18n';
import { getAstroClickText } from '../../../i18n/astroclick';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const text = getAstroClickText(locale);
---
<BaseLayout title={text.title} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-serif font-bold text-cream">{text.title}</h1>
      <p class="text-sm text-muted mt-1">{text.subtitle}</p>
    </div>
    <AstroClickApp client:load locale={locale} />
  </div>
</BaseLayout>
