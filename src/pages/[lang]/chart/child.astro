---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ChildChartApp from '../../../components/chart/ChildChartApp.tsx';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);

const PAGE_LABELS = {
  pt: {
    title: 'Mapa Infantil',
    breadcrumb: 'Mapa Infantil',
    intro: 'Descubra os talentos naturais do seu filho, como ele aprende melhor, o que precisa para se sentir seguro e como expressa sua energia no mundo.',
    summary: '🌈 Como usar o Mapa Infantil?',
    note: '🌈 Lembrete amoroso',
  },
  en: {
    title: 'Child Chart',
    breadcrumb: 'Child Chart',
    intro: 'Discover your child’s natural talents, how they learn best, what they need to feel safe and how they express their energy in the world.',
    summary: '🌈 How to use the Child Chart?',
    note: '🌈 Loving reminder',
  },
} as const;

const page = PAGE_LABELS[locale] ?? PAGE_LABELS.en;
---
<BaseLayout title={page.title} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-8">
      <nav class="text-sm text-muted mb-4">
        <a href={localePath('/', locale)} class="hover:text-brand-600">{t.nav.home}</a>
        {' '}→{' '}
        <a href={localePath('/chart/natal', locale)} class="hover:text-brand-600">{t.nav.natal}</a>
        {' '}→{' '}
        <span class="text-cream">{page.breadcrumb}</span>
      </nav>

      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl">👶</span>
        <h1 class="text-2xl sm:text-3xl font-serif font-bold text-cream">{page.title}</h1>
      </div>
    </div>
    <ChildChartApp client:load locale={locale} />

  </div>
</BaseLayout>
