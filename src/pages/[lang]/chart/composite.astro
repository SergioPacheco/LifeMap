---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
import CompositeApp from '../../../components/chart/CompositeApp.tsx';
---
<BaseLayout title={t.nav.composite} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-serif font-bold text-cream">{t.nav.composite}</h1>
      <p class="text-sm text-muted mt-1">O mapa da relação — como se o casal fosse uma entidade única com propósito próprio</p>
    </div>
    <CompositeApp client:load />
  </div>
</BaseLayout>
