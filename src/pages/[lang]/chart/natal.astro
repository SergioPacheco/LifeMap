---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NatalApp from '../../../components/chart/NatalApp.tsx';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';
import { getNatalGuide } from '../../../i18n/chart-guides';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
const page = getNatalGuide(locale);
---

<BaseLayout title={t.nav.natal} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">

    <!-- Header -->
    <div class="mb-8">
      <nav class="text-sm text-muted mb-4">
        <a href={localePath('/', locale)} class="hover:text-brand-600">{t.nav.home}</a> → <span class="text-cream">{t.nav.natal}</span>
      </nav>

      <h1 class="text-2xl sm:text-3xl font-serif font-bold text-cream mb-3">{page.title}</h1>
      <p class="text-muted text-base max-w-3xl leading-relaxed" set:html={page.intro} />
    </div>

    <!-- Explicação colapsável -->
    <details class="mb-8 group">
      <summary class="cursor-pointer flex items-center gap-2 text-sm font-medium text-gold hover:text-gold-light transition-colors">
        <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        {page.summary}
      </summary>

      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">◎</span> {page.wheelTitle}
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2" set:html={page.wheel[0]} />
          <p class="text-xs text-cream-dark leading-relaxed" set:html={page.wheel[1]} />
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">☉</span> {page.planetsTitle}
          </h3>
          <ul class="space-y-1.5 text-xs text-cream-dark">
            <li set:html={page.planets[0]} />
            <li set:html={page.planets[1]} />
            <li set:html={page.planets[2]} />
            <li set:html={page.planets[3]} />
            <li set:html={page.planets[4]} />
            <li set:html={page.planets[5]} />
          </ul>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">🏠</span> {page.housesTitle}
          </h3>
          <ul class="space-y-1.5 text-xs text-cream-dark">
            <li set:html={page.houses[0]} />
            <li set:html={page.houses[1]} />
            <li set:html={page.houses[2]} />
            <li set:html={page.houses[3]} />
            <li class="text-muted italic">{page.houses[4]}</li>
          </ul>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">🔗</span> {page.aspectsTitle}
          </h3>
          <ul class="space-y-1.5 text-xs text-cream-dark">
            <li set:html={page.aspects[0]} />
            <li set:html={page.aspects[1]} />
            <li set:html={page.aspects[2]} />
            <li set:html={page.aspects[3]} />
            <li set:html={page.aspects[4]} />
          </ul>
        </div>
      </div>
    </details>

    <!-- App -->
    <NatalApp client:load locale={locale} />

    <!-- Legenda -->
    <div class="mt-8 glass rounded-xl p-5 border border-base-300">
      <h3 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">{page.tipTitle}</h3>
      <p class="text-xs text-cream-dark leading-relaxed" set:html={page.tip} />
    </div>
  </div>
</BaseLayout>
