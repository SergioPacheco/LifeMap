---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';
import { getTransitGuide } from '../../../i18n/chart-guides';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
const page = getTransitGuide(locale);
import TransitsApp from '../../../components/chart/TransitsApp.tsx';
---
<BaseLayout title={t.nav.transits} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">

    <!-- Header -->
    <div class="mb-8">
      <nav class="text-sm text-muted mb-4">
        <a href={localePath('/chart/natal', locale)} class="hover:text-brand-600">{t.nav.charts}</a> → <span class="text-cream">{t.nav.transits}</span>
      </nav>

      <h1 class="text-2xl sm:text-3xl font-serif font-bold text-cream mb-3">{page.title}</h1>
      <p class="text-muted text-base max-w-3xl leading-relaxed" set:html={page.intro} />
    </div>

    <!-- Explicação colapsável -->
    <details class="mb-8 group">
      <summary class="cursor-pointer flex items-center gap-2 text-sm font-medium text-gold hover:text-gold-light transition-colors">
        <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        {page.summary}
      </summary>

      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">↻</span> {page.sectionTitles[0]}
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2" set:html={page.what[0]} />
          <p class="text-xs text-cream-dark leading-relaxed" set:html={page.what[1]} />
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">⏱</span> {page.sectionTitles[1]}
          </h3>
          <ul class="space-y-1.5 text-xs text-cream-dark">
            <li set:html={page.durations[0]} />
            <li set:html={page.durations[1]} />
            <li set:html={page.durations[2]} />
            <li set:html={page.durations[3]} />
            <li set:html={page.durations[4]} />
            <li set:html={page.durations[5]} />
          </ul>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">🔍</span> {page.sectionTitles[2]}
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2" set:html={page.interpretIntro} />
          <ul class="space-y-1 text-xs text-cream-dark">
            <li>• <span set:html={page.aspectMeanings[0]} /></li>
            <li>• <span set:html={page.aspectMeanings[1]} /></li>
            <li>• <span set:html={page.aspectMeanings[2]} /></li>
            <li>• <span set:html={page.aspectMeanings[3]} /></li>
          </ul>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">⚡</span> {page.sectionTitles[3]}
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2">{page.priorityIntro}</p>
          <ol class="space-y-1 text-xs text-cream-dark list-decimal list-inside">
            <li set:html={page.priorities[0]} />
            <li set:html={page.priorities[1]} />
            <li set:html={page.priorities[2]} />
            <li set:html={page.priorities[3]} />
          </ol>
        </div>
      </div>
    </details>

    <!-- App -->
    <TransitsApp client:load locale={locale} />

    <!-- Legenda -->
    <div class="mt-8 glass rounded-xl p-5 border border-base-300">
      <h3 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">{page.legendTitle}</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs text-cream-dark">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-blue-400/60"></span>
          <span>{page.legend[0]}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-gold/60"></span>
          <span>{page.legend[1]}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-red-400/60"></span>
          <span>{page.legend[2]}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-purple-400/60"></span>
          <span>{page.legend[3]}</span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
