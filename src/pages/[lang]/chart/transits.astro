---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
import TransitsApp from '../../../components/chart/TransitsApp.tsx';
---
<BaseLayout title={t.nav.transits} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-serif font-bold text-cream">{t.nav.transits}</h1>
      <p class="text-sm text-muted mt-1">Planetas em movimento hoje sobre o seu mapa — o que está ativado agora na sua vida</p>
    </div>
    <TransitsApp client:load />
  </div>
</BaseLayout>
