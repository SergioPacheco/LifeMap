---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
import SynastryApp from '../../../components/chart/SynastryApp.tsx';
---
<BaseLayout title={t.nav.synastry} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">

    <!-- Header -->
    <div class="mb-8">
      <nav class="text-sm text-muted mb-4">
        <a href={localePath('/chart/natal', locale)} class="hover:text-brand-600">{t.nav.charts}</a> → <span class="text-cream">{t.nav.synastry}</span>
      </nav>

      <h1 class="text-2xl sm:text-3xl font-serif font-bold text-cream mb-3">Sinastria</h1>
      <p class="text-muted text-base max-w-3xl leading-relaxed">
        A sinastria compara <strong class="text-cream">dois mapas natais lado a lado</strong> para revelar a dinâmica energética entre duas pessoas — pontos de atração magnética, desafios recorrentes e potencial de crescimento mútuo.
      </p>
    </div>

    <!-- Explicação colapsável -->
    <details class="mb-8 group">
      <summary class="cursor-pointer flex items-center gap-2 text-sm font-medium text-gold hover:text-gold-light transition-colors">
        <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        Como funciona? O que estou vendo?
      </summary>

      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">♡</span> O que é Sinastria?
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2">
            Sobrepõe-se os planetas de uma pessoa sobre o mapa da outra. Quando o <strong class="text-cream">Vênus de A está em conjunção com Marte de B</strong>, por exemplo, há uma atração física e romântica natural entre eles.
          </p>
          <p class="text-xs text-cream-dark leading-relaxed">
            Não existe "casal perfeito" — toda sinastria tem harmonia E tensão. A tensão é o que gera crescimento.
          </p>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">🔥</span> Aspectos-chave para observar
          </h3>
          <ul class="space-y-1.5 text-xs text-cream-dark">
            <li><strong class="text-cream">Sol-Lua</strong> — entendimento profundo (Sol = ego, Lua = emoção)</li>
            <li><strong class="text-cream">Vênus-Marte</strong> — atração física e romântica</li>
            <li><strong class="text-cream">Lua-Lua</strong> — compatibilidade emocional e doméstica</li>
            <li><strong class="text-cream">Saturno com planetas pessoais</strong> — compromisso mas rigidez</li>
            <li><strong class="text-cream">Plutão com planetas pessoais</strong> — intensidade transformadora</li>
          </ul>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">🏠</span> Casas sobrepostas
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2">
            Onde os planetas do outro <strong class="text-cream">caem nas suas casas</strong> mostra que área da sua vida essa pessoa ativa:
          </p>
          <ul class="space-y-1 text-xs text-cream-dark">
            <li>• Planetas na Casa 1 → impacto na identidade</li>
            <li>• Planetas na Casa 5 → romance e diversão</li>
            <li>• Planetas na Casa 7 → parceria formal</li>
            <li>• Planetas na Casa 8 → intimidade profunda</li>
          </ul>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">⚖️</span> Sinastria vs Composto
          </h3>
          <div class="text-xs text-cream-dark space-y-2">
            <div class="flex items-start gap-2">
              <span class="text-pink-400 flex-shrink-0">♡</span>
              <span><strong class="text-cream">Sinastria</strong> = como EU experimento VOCÊ (e vice-versa). É subjetivo — cada pessoa sente diferente.</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-purple-400 flex-shrink-0">∞</span>
              <span><strong class="text-cream">Composto</strong> = o mapa da RELAÇÃO como entidade. É objetivo — mostra o propósito e destino do casal.</span>
            </div>
            <p class="text-muted italic mt-2">Use ambos para uma visão completa do relacionamento.</p>
          </div>
        </div>
      </div>
    </details>

    <!-- App -->
    <SynastryApp client:load />

    <!-- Legenda -->
    <div class="mt-8 glass rounded-xl p-5 border border-base-300">
      <h3 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Legenda de leitura</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs text-cream-dark">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-blue-400/60"></span>
          <span>Anel interno = mapa da Pessoa 1</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-pink-400/60"></span>
          <span>Anel externo = mapa da Pessoa 2</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-gold/60"></span>
          <span>Linhas = aspectos cruzados (interação entre os dois mapas)</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-green-400/60"></span>
          <span>Aspectos harmônicos = fluxo natural entre vocês</span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
