---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
import ProgressionsApp from '../../../components/chart/ProgressionsApp.tsx';
---
<BaseLayout title={t.nav.progressions} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-8">
      <nav class="text-sm text-muted mb-4">
        <a href={localePath('/chart/natal', locale)} class="hover:text-brand-600">{t.nav.charts}</a> → <span class="text-cream">{t.nav.progressions}</span>
      </nav>
      <h1 class="text-2xl sm:text-3xl font-serif font-bold text-cream">{t.nav.progressions}</h1>
    </div>
    <ProgressionsApp client:load locale={locale} />
  </div>
</BaseLayout>
