---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, localePath, type Locale } from '../../../i18n';
import { getSolarReturnGuide } from '../../../i18n/solar-return-guide';
export function getStaticPaths() { return supportedLocales.map(lang => ({ params: { lang } })); }
const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
const guide = getSolarReturnGuide(locale);
import SolarReturnApp from '../../../components/chart/SolarReturnApp.tsx';
---
<BaseLayout title={t.nav.solarReturn} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">

    <!-- Header -->
    <div class="mb-8">
      <nav class="text-sm text-muted mb-4">
        <a href={localePath('/chart/natal', locale)} class="hover:text-brand-600">{t.nav.charts}</a> → <span class="text-cream">{t.nav.solarReturn}</span>
      </nav>

      <h1 class="text-2xl sm:text-3xl font-serif font-bold text-cream mb-3">{t.nav.solarReturn}</h1>
      <p class="text-muted text-base max-w-3xl leading-relaxed" set:html={guide.intro} />
    </div>

    <!-- Explicação colapsável -->
    <details class="mb-8 group">
      <summary class="cursor-pointer flex items-center gap-2 text-sm font-medium text-gold hover:text-gold-light transition-colors">
        <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        {guide.summary}
      </summary>

      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">☼</span> {guide.titles[0]}
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2">{guide.definition[0]}</p>
          <p class="text-xs text-cream-dark leading-relaxed">{guide.definition[1]}</p>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">🔍</span> {guide.titles[1]}
          </h3>
          <ul class="space-y-1.5 text-xs text-cream-dark">
            <li set:html={guide.observe[0]} />
            <li set:html={guide.observe[1]} />
            <li set:html={guide.observe[2]} />
            <li set:html={guide.observe[3]} />
            <li set:html={guide.observe[4]} />
            <li set:html={guide.observe[5]} />
          </ul>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">📍</span> {guide.titles[2]}
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2" set:html={guide.location[0]} />
          <p class="text-xs text-muted italic">{guide.location[1]}</p>
        </div>

        <div class="glass rounded-xl p-5 border border-base-300">
          <h3 class="text-sm font-semibold text-cream mb-3 flex items-center gap-2">
            <span class="text-gold">📅</span> {guide.titles[3]}
          </h3>
          <p class="text-xs text-cream-dark leading-relaxed mb-2" set:html={guide.validity[0]} />
          <p class="text-xs text-cream-dark leading-relaxed">{guide.validity[1]}</p>
        </div>
      </div>
    </details>

    <!-- App -->
    <SolarReturnApp client:load locale={locale} />

    <!-- Legenda -->
    <div class="mt-8 glass rounded-xl p-5 border border-base-300">
      <h3 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">{guide.readingTitle}</h3>
      <p class="text-xs text-cream-dark leading-relaxed" set:html={guide.reading} />
    </div>
  </div>
</BaseLayout>
