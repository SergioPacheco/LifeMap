---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
import AllSignsDailyHoroscope from '../../../components/chart/AllSignsDailyHoroscope.tsx';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---

<BaseLayout title={t.nav.dailyHoroscope} locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <AllSignsDailyHoroscope client:load locale={locale} />
  </div>
</BaseLayout>
