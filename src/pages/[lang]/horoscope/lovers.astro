---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, supportedLocales, type Locale } from '../../../i18n';
import LoversSelector from '../../../components/horoscope/LoversSelector.tsx';

export function getStaticPaths() {
  return supportedLocales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const t = getTranslations(locale);
---

<BaseLayout title="Compatibilidade dos Signos" locale={locale}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <LoversSelector client:load locale={locale} />
  </div>
</BaseLayout>
